# name: test/sql/secretscan.test
# description: vgi-secretscan — secret_contains scalar + secret_scan table function (offline, redacted output, no network)
# group: [vgi_secretscan]

require-env VGI_SECRETSCAN_WORKER

# haybarn-unittest does NOT autoload the extension for `require vgi` (it is
# silently SKIPPED). Load it explicitly instead.
statement ok
LOAD vgi;

statement ok
ATTACH 'secretscan' AS secretscan (TYPE vgi, LOCATION '${VGI_SECRETSCAN_WORKER}');

# ---- secret_contains: predicate for filtering ----
# All fixtures below are CLEARLY FAKE, non-live test secrets.

# A fake AWS access key id -> true.
query T
SELECT secretscan.secret_contains('deploy AKIAZ3MZ7EXAMPLE4Q2T now');
----
true

# A fake Slack bot token -> true.
query T
SELECT secretscan.secret_contains('SLACK_TOKEN=xoxb-1234567890-1234567890123-AbCdEfGhIjKlMnOpQrStUvWx');
----
true

# Clean prose -> false.
query T
SELECT secretscan.secret_contains('the quick brown fox jumps over the lazy dog');
----
false

# NULL input -> NULL (DuckDB short-circuits NULL scalar inputs; never an error).
query T
SELECT secretscan.secret_contains(NULL);
----
NULL

# secret_contains works as a WHERE-clause filter over a column of values.
statement ok
CREATE TEMP TABLE blobs(id INTEGER, body VARCHAR);

statement ok
INSERT INTO blobs VALUES
  (1, 'nothing to see here'),
  (2, 'aws key AKIAZ3MZ7EXAMPLE4Q2T leaked'),
  (3, 'token xoxb-1234567890-1234567890123-AbCdEfGhIjKlMnOpQrStUvWx'),
  (4, 'SELECT * FROM users');

query I
SELECT count(*) FROM blobs WHERE secretscan.secret_contains(body);
----
2

# ---- secret_scan: one row per finding ----

# A single AWS key yields exactly one finding.
query I
SELECT count(*) FROM secretscan.secret_scan('deploy AKIAZ3MZ7EXAMPLE4Q2T now');
----
1

# The finding is redacted (never the raw key), at the right offset, with a
# high confidence for this structurally-distinctive rule.
query TTTIR
SELECT rule_id, description IS NOT NULL, match_redacted, start_offset, confidence
FROM secretscan.secret_scan('deploy AKIAZ3MZ7EXAMPLE4Q2T now');
----
aws-access-token	true	AKIA********4Q2T	7	0.95

# The redacted match must NOT contain the full raw secret.
query I
SELECT count(*) FROM secretscan.secret_scan('deploy AKIAZ3MZ7EXAMPLE4Q2T now')
WHERE match_redacted LIKE '%AKIAZ3MZ7EXAMPLE4Q2T%';
----
0

# Entropy is reported and positive for a real secret.
query T
SELECT entropy > 3.0 FROM secretscan.secret_scan('token xoxb-1234567890-1234567890123-AbCdEfGhIjKlMnOpQrStUvWx');
----
true

# A Slack token is detected and redacted.
query TT
SELECT rule_id, match_redacted
FROM secretscan.secret_scan('token xoxb-1234567890-1234567890123-AbCdEfGhIjKlMnOpQrStUvWx');
----
slack-bot-token	xoxb********UvWx

# Clean text yields zero rows.
query I
SELECT count(*) FROM secretscan.secret_scan('the quick brown fox jumps over the lazy dog');
----
0

# NULL text yields zero rows (not an error).
query I
SELECT count(*) FROM secretscan.secret_scan(NULL);
----
0

# Multiple distinct secrets in one blob produce multiple rows, ordered by offset.
query TI
SELECT rule_id, start_offset
FROM secretscan.secret_scan(
  E'aws AKIAZ3MZ7EXAMPLE4Q2T\nslack xoxb-1234567890-1234567890123-AbCdEfGhIjKlMnOpQrStUvWx')
ORDER BY start_offset;
----
aws-access-token	4
slack-bot-token	31

# Thresholding on confidence keeps only the structurally-certain leaks.
query I
SELECT count(*) FROM secretscan.secret_scan('deploy AKIAZ3MZ7EXAMPLE4Q2T now')
WHERE confidence >= 0.9;
----
1
